{
  "version": 3,
  "configurePresets": [
    {
      "name": "base-win-x64",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "base-win-x86",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "base-linux-x64",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    {
      "name": "base-linux-x86",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_C_FLAGS": "-m32",
        "CMAKE_CXX_FLAGS": "-m32"
      }
    },

    {
      "name": "win-x64",
      "displayName": "Windows x64 (MSVC)",
      "description": "Run from x64 Native Tools Command Prompt for VS",
      "inherits": "base-win-x64"
    },
    {
      "name": "win-x86",
      "displayName": "Windows x86 (MSVC)",
      "description": "Run from x86 Native Tools Command Prompt for VS",
      "inherits": "base-win-x86"
    },

    {
      "name": "linux-x64-release",
      "displayName": "Linux x86_64 Release (GCC)",
      "inherits": "base-linux-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-x64-debug",
      "displayName": "Linux x86_64 Debug (GCC)",
      "inherits": "base-linux-x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-x86-release",
      "displayName": "Linux x86 Release (GCC)",
      "inherits": "base-linux-x86",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-x86-debug",
      "displayName": "Linux x86 Debug (GCC)",
      "inherits": "base-linux-x86",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },

    {
      "name": "linux-x64-clang-release",
      "displayName": "Linux x86_64 Release (Clang)",
      "inherits": "linux-x64-release",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "linux-x64-clang-debug",
      "displayName": "Linux x86_64 Debug (Clang)",
      "inherits": "linux-x64-debug",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "linux-x86-clang-release",
      "displayName": "Linux x86 Release (Clang)",
      "inherits": "linux-x86-release",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "linux-x86-clang-debug",
      "displayName": "Linux x86 Debug (Clang)",
      "inherits": "linux-x86-debug",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "win-x64-release",
      "displayName": "Windows x64 Release",
      "configurePreset": "win-x64",
      "configuration": "Release"
    },
    {
      "name": "win-x64-debug",
      "displayName": "Windows x64 Debug",
      "configurePreset": "win-x64",
      "configuration": "Debug"
    },
    {
      "name": "win-x86-release",
      "displayName": "Windows x86 Release",
      "configurePreset": "win-x86",
      "configuration": "Release"
    },
    {
      "name": "win-x86-debug",
      "displayName": "Windows x86 Debug",
      "configurePreset": "win-x86",
      "configuration": "Debug"
    },

    {
      "name": "linux-x64-release",
      "displayName": "Linux x86_64 GCC Release",
      "configurePreset": "linux-x64-release"
    },
    {
      "name": "linux-x64-debug",
      "displayName": "Linux x86_64 GCC Debug",
      "configurePreset": "linux-x64-debug"
    },
    {
      "name": "linux-x86-release",
      "displayName": "Linux x86 GCC Release",
      "configurePreset": "linux-x86-release"
    },
    {
      "name": "linux-x86-debug",
      "displayName": "Linux x86 GCC Debug",
      "configurePreset": "linux-x86-debug"
    },

    {
      "name": "linux-x64-clang-release",
      "displayName": "Linux x86_64 Clang Release",
      "configurePreset": "linux-x64-clang-release"
    },
    {
      "name": "linux-x64-clang-debug",
      "displayName": "Linux x86_64 Clang Debug",
      "configurePreset": "linux-x64-clang-debug"
    },
    {
      "name": "linux-x86-clang-release",
      "displayName": "Linux x86 Clang Release",
      "configurePreset": "linux-x86-clang-release"
    },
    {
      "name": "linux-x86-clang-debug",
      "displayName": "Linux x86 Clang Debug",
      "configurePreset": "linux-x86-clang-debug"
    }
  ]
}
